@model CarSalesAndInventoryManagementSystem.Models.Car

@{
    ViewBag.Title = Model.Brand + " " + Model.Model;
}

<style>
    .details-img-container {
        border: 1px solid #eee;
        border-radius: 8px;
        overflow: hidden;
    }

        .details-img-container img {
            width: 100%;
            height: auto;
            display: block;
        }

    .price-display {
        font-size: 2.5em;
        font-weight: bold;
        color: #28a745;
        margin-bottom: 20px;
    }

    .spec-table {
        font-size: 1.1em;
    }
</style>

<div class="container" style="margin-top: 30px;">
    <div class="row">
        <div class="col-md-7">
            <div class="details-img-container">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? $"https://placehold.co/600x400/EFEFEF/AAAAAA?text={Model.Brand}+{Model.Model}" : Model.ImageUrl)"
                     alt="Image of @Model.Brand @Model.Model"
                     onerror="this.onerror=null; this.src='https://placehold.co/600x400/EFEFEF/AAAAAA?text=Image+Not+Found';">
            </div>
        </div>
        <div class="col-md-5">
            <h1>@Model.Brand @Model.Model</h1>
            <hr />
            <div class="price-display">
                @String.Format("{0:C}", Model.Price)
            </div>

            <p>
                <span class="label label-success">In Stock: @Model.Stock available</span>
            </p>
            <br />

            @using (Html.BeginForm("AddToCart", "Cart", FormMethod.Post))
            {
                @Html.Hidden("id", Model.CarID)
                @Html.Hidden("productType", "Car")
                <button type="submit" class="btn btn-success btn-lg">Add to Cart</button>
            }
            @Html.ActionLink("Book a Test Drive", "Create", "TestDrive", new { carId = Model.CarID }, new { @class = "btn btn-info btn-lg", @style = "margin-top:10px;" })
        </div>
    </div>

    <div class="row" style="margin-top: 40px;">
        <div class="col-md-12">
            <h3>Vehicle Specifications</h3>
            <table class="table table-striped table-bordered spec-table">
                <tr>
                    <th style="width: 20%;">Brand</th>
                    <td>@Model.Brand</td>
                </tr>
                <tr>
                    <th>Model</th>
                    <td>@Model.Model</td>
                </tr>
                <tr>
                    <th>Engine Type</th>
                    <td>@Model.EngineType</td>
                </tr>
                <tr>
                    <th>Mileage</th>
                    <td>@Model.Mileage km/l</td>
                </tr>
                <tr>
                    <th>Tank Capacity</th>
                    <td>@Model.TankCapacity Liters</td>
                </tr>
            </table>
        </div>
    </div>

    <hr />
    @Html.ActionLink("<< Back to All Cars", "BrowseCars", "Customer", null, new { @class = "btn btn-default" })
</div>
