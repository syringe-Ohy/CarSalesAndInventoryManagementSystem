@{
    ViewBag.Title = "Contact";
    ViewBag.Message = "We’d love to hear from you! Reach out to us anytime.";
}

<style>
    main {
        max-width: 700px;
        margin: 3rem auto;
        padding: 2rem 2.5rem;
        background-color: #f9f9f9;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #333;
    }

    h2#title {
        text-align: center;
        font-size: 2.8rem;
        color: #007bff;
        margin-bottom: 0.2rem;
    }

    h3 {
        text-align: center;
        font-weight: 500;
        font-size: 1.3rem;
        margin-bottom: 2rem;
        color: #555;
    }

    address {
        font-style: normal;
        line-height: 1.6;
        font-size: 1.1rem;
        color: #444;
        margin-bottom: 2rem;
        border-left: 4px solid #007bff;
        padding-left: 1rem;
        background-color: #e9f1ff;
        border-radius: 6px;
    }

    abbr[title] {
        border-bottom: 1px dotted #666;
        cursor: help;
    }

    a {
        color: #007bff;
        text-decoration: none;
    }

        a:hover {
            text-decoration: underline;
        }
</style>

<main aria-labelledby="title">
    <h2 id="title">@ViewBag.Title</h2>
    <h3>@ViewBag.Message</h3>

    <address>
        Kuril, Dhaka-1230,<br />
        Bangladesh<br />
        <abbr title="Phone"></abbr> +880 1703-223153
        <br />
        <abbr title="Phone"></abbr> +880 1601-887741
    </address>


    <address>
        <strong>Support:</strong> <a href="mailto:naimurrohan204@gmail.com">naimurrohan204@gmail.com</a><br />
        <strong>Marketing:</strong> <a href="mailto:rizviohy@icloud.com">rizviohy@icloud.com</a>
    </address>
</main>
