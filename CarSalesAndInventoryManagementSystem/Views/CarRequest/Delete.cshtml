@model CarSalesAndInventoryManagementSystem.Models.CarRequest

@{

    ViewBag.Title = "Delete Request";

}

<div class="container" style="max-width: 700px;">
    <h3>Are you sure you want to delete this request?</h3>
    <p class="text-danger">This action cannot be undone.</p>
    <hr />
    <div>
        <h4>Request for: @Model.Brand @Model.Model</h4>
        <dl class="dl-horizontal">
            <dt>Date Requested</dt>
            <dd>@Model.RequestDate.ToString("dd MMM yyyy")</dd>

            <dt>Status</dt>
            <dd>@Model.Status</dd>
        </dl>

        @using (Html.BeginForm())

        {

            @Html.AntiForgeryToken()
            <div class="form-actions no-color">
                <input type="submit" value="Delete" class="btn btn-danger" /> |

                @Html.ActionLink("Cancel and Back to My Requests", "MyCarRequests")
            </div>

        }
    </div>
</div>


