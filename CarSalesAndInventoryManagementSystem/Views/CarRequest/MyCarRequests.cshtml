@model IEnumerable<CarSalesAndInventoryManagementSystem.Models.CarRequest>

@{

    ViewBag.Title = "My Car Requests";

}

<div class="container">
    <h2>My Car Requests</h2>
    <hr />

    <p>Here is a list of the special car requests you have submitted. You can edit or delete them as long as the status is "New".</p>

    @if (TempData["SuccessMessage"] != null)

    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>

    }

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Requested Car</th>
                <th>Date</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>

            @foreach (var item in Model)

            {
                <tr>
                    <td>@item.Brand @item.Model</td>
                    <td>@item.RequestDate.ToString("dd MMM yyyy")</td>
                    <td><span class="label label-info">@item.Status</span></td>
                    <td class="text-right">

                        @if (item.Status == "New")

                        {

                            @Html.ActionLink("Edit", "Edit", new { id = item.CarRequestID }, new { @class = "btn btn-xs btn-warning" })

                            @:|

                            @Html.ActionLink("Delete", "Delete", new { id = item.CarRequestID }, new { @class = "btn btn-xs btn-danger" })

                        }

                        else

                        {
                            <span class="text-muted">Processed</span>

                        }
                    </td>
                </tr>

            }
        </tbody>
    </table>

    <div class="form-actions no-color" style="margin-top: 20px;">

        @Html.ActionLink("<< Back to Dashboard", "Dashboard", "Customer", null, new { @class = "btn btn-default" })
    </div>
</div>


