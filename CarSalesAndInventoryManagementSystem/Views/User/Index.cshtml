@model IEnumerable<CarSalesAndInventoryManagementSystem.Models.User>

@{
    ViewBag.Title = "Manage Users";
}

<div class="container">
    <h2>Manage All Users</h2>
    <hr />

    <p>
        @Html.ActionLink("Create New User", "AddAdmin", "Admin", null, new { @class = "btn btn-primary" })
    </p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <table class="table table-striped table-bordered">
        <thead class="info">
            <tr>
                <th>@Html.DisplayNameFor(model => model.UserID)</th>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.Email)</th>
                <th>@Html.DisplayNameFor(model => model.DOB)</th>
                <th>@Html.DisplayNameFor(model => model.Role)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.UserID</td>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.DOB.ToString("yyyy-MM-dd")</td>
                    <td>
                        @if (item.Role == "Admin")
                        {
                            <span class="label label-danger">@item.Role</span>
                        }
                        else
                        {
                            <span class="label label-success">@item.Role</span>
                        }
                    </td>
                    <td>
                        @Html.ActionLink("Delete", "Delete", "Admin", new { id = item.UserID }, new
                        {
                            @class = "btn btn-danger btn-sm",
                            onclick = "return confirm('Are you sure you want to delete this user?');"
                        })
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="form-actions no-color">
        @Html.ActionLink("<< Back to Admin Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-default" })
    </div>
</div>
