@model CarSalesAndInventoryManagementSystem.Models.Car

@{
    ViewBag.Title = "Delete Car";
}

<div class="container" style="max-width: 800px; margin-top: 30px;">
    <h2>Confirm Deletion</h2>
    <h3 class="text-danger">Are you sure you want to permanently delete this car from the inventory?</h3>
    <hr />

    <div class="panel panel-danger">
        <div class="panel-heading">
            <h3 class="panel-title">@Html.DisplayFor(model => model.Brand) @Html.DisplayFor(model => model.Model)</h3>
        </div>
        <div class="panel-body">
            <dl class="dl-horizontal">
                <dt>@Html.DisplayNameFor(model => model.EngineType)</dt>
                <dd>@Html.DisplayFor(model => model.EngineType)</dd>

                <dt>@Html.DisplayNameFor(model => model.Mileage)</dt>
                <dd>@Html.DisplayFor(model => model.Mileage)</dd>

                <dt>@Html.DisplayNameFor(model => model.TankCapacity)</dt>
                <dd>@Html.DisplayFor(model => model.TankCapacity)</dd>

                <dt>@Html.DisplayNameFor(model => model.Price)</dt>
                <dd>@String.Format("{0:C}", Model.Price)</dd>

                <dt>@Html.DisplayNameFor(model => model.Stock)</dt>
                <dd>@Html.DisplayFor(model => model.Stock)</dd>
            </dl>
        </div>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-actions no-color">
            <input type="submit" value="Delete" class="btn btn-danger" /> |
            @Html.ActionLink("Cancel and Return to Inventory", "CarInventory")
        </div>
    }
</div>
