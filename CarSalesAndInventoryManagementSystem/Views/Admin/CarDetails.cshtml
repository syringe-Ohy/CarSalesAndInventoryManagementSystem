@model CarSalesAndInventoryManagementSystem.Models.Car

@{
    ViewBag.Title = "Admin Car Details";
}

<div class="container" style="margin-top: 30px;">
    <h2>Car Details (Admin View)</h2>
    <hr />

    <div class="row">
        <div class="col-md-7">
            <div style="border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? $"https://placehold.co/600x400/EFEFEF/AAAAAA?text={Model.Brand}+{Model.Model}" : Model.ImageUrl)"
                     alt="Image of @Model.Brand @Model.Model"
                     class="img-responsive"
                     onerror="this.onerror=null; this.src='https://placehold.co/600x400/EFEFEF/AAAAAA?text=Image+Not+Found';">
            </div>
        </div>
        <div class="col-md-5">
            <h3>@Model.Brand @Model.Model</h3>
            <p class="text-muted">Car ID: @Model.CarID</p>
            <hr />
            <dl class="dl-horizontal">
                <dt>Price</dt>
                <dd>@String.Format("{0:C}", Model.Price)</dd>

                <dt>Stock</dt>
                <dd>@Model.Stock units</dd>
            </dl>
            @Html.ActionLink("Edit This Car", "EditCar", "Admin", new { id = Model.CarID }, new { @class = "btn btn-warning" })
        </div>
    </div>

    <div class="row" style="margin-top: 40px;">
        <div class="col-md-12">
            <h3>Full Specifications</h3>
            <table class="table table-bordered">
                <tr>
                    <th style="width: 20%;">Brand</th>
                    <td>@Model.Brand</td>
                </tr>
                <tr>
                    <th>Model</th>
                    <td>@Model.Model</td>
                </tr>
                <tr>
                    <th>Engine Type</th>
                    <td>@Model.EngineType</td>
                </tr>
                <tr>
                    <th>Mileage</th>
                    <td>@Model.Mileage km/l</td>
                </tr>
                <tr>
                    <th>Tank Capacity</th>
                    <td>@Model.TankCapacity Liters</td>
                </tr>
            </table>
        </div>
    </div>

    <hr />
    @Html.ActionLink("<< Back to Car Inventory", "CarInventory", "Admin", null, new { @class = "btn btn-default" })
</div>

