@model IEnumerable<CarSalesAndInventoryManagementSystem.Models.Car>

@{
    ViewBag.Title = "Manage Car Inventory";
}

<div class="container">
    <h2>Manage Car Inventory & Stock</h2>
    <hr />

    <p>
        @Html.ActionLink("Add New Car", "AddCar", null, new { @class = "btn btn-primary" })
    </p>

    <table class="table table-striped table-bordered">
        <tr class="info">
            <th>Image</th>
            <th>Brand</th>
            <th>Model</th>
            <th>Engine Type</th>
            <th>Price</th>
            <th>Stock Level</th>
            <th>Actions</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? $"https://placehold.co/120x80/EFEFEF/AAAAAA?text=No+Image" : item.ImageUrl)"
                         class="inventory-thumbnail"
                         alt="Image of @item.Brand @item.Model"
                         onerror="this.onerror=null; this.src='https://placehold.co/120x80/EFEFEF/AAAAAA?text=Error';">
                </td>
                <td>@Html.DisplayFor(modelItem => item.Brand)</td>
                <td>@Html.DisplayFor(modelItem => item.Model)</td>
                <td>@Html.DisplayFor(modelItem => item.EngineType)</td>
                <td>@String.Format("{0:C}", item.Price)</td>
                <td>
                    @if (item.Stock < 5)
                    {
                        <span class="label label-danger">Low Stock (@item.Stock)</span>
                    }
                    else
                    {
                        <span class="label label-success">@item.Stock</span>
                    }
                </td>
                <<td>
                @Html.ActionLink("Edit", "EditCar", "Admin", new { id=item.CarID }, new { @class="btn btn-xs btn-warning" }) |
                @Html.ActionLink("Details", "CarDetails", "Admin", new { id = item.CarID }, new { @class = "btn btn-xs btn-info" }) |
                @Html.ActionLink("Delete", "DeleteCar", "Admin", new { id=item.CarID }, new { @class="btn btn-xs btn-danger" })
            </td>
            </tr>
        }

    </table>
    @* Back BUTTON *@
    <div class="form-actions no-color" style="margin-top: 20px;">
        @Html.ActionLink("<< Back to Admin Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-default" })
    </div>
</div>
