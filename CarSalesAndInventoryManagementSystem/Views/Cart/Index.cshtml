@model IEnumerable<CarSalesAndInventoryManagementSystem.ViewModels.CartItem>

@{
    ViewBag.Title = "Shopping Cart";
    decimal cartTotal = Model.Sum(item => item.Subtotal);
}

<div class="container" style="margin-top: 30px;">
    <h2>Your Shopping Cart</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-info">
            <p>@ViewBag.Message</p>
            @Html.ActionLink("Start Shopping", "BrowseCars", "Customer", null, new { @class = "btn btn-primary" })
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <table class="table">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="width: 120px;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="img-responsive img-thumbnail" style="width: 100px;" alt="@item.ProductName" />
                                }
                            </td>
                            <td>
                                <h4>@item.ProductName</h4>
                                <p>Type: @item.ProductType</p>
                            </td>
                            <td class="text-center">
                                <h4>Quantity</h4>
                                @using (Html.BeginForm("UpdateQuantity", "Cart", FormMethod.Post, new { @class = "form-inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("productId", item.ProductId)
                                    @Html.Hidden("productType", item.ProductType)
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" style="width: 60px;" class="form-control" />
                                    <button type="submit" class="btn btn-primary btn-sm" style="margin-left:5px;">Update</button>
                                }
                            </td>
                            <td class="text-right">
                                <h4>Price</h4>
                                @String.Format("{0:C}", item.Price)
                            </td>
                            <td class="text-right">
                                @using (Html.BeginForm("RemoveFromCart", "Cart", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("productId", item.ProductId)
                                    @Html.Hidden("productType", item.ProductType)
                                    <button type="submit" class="btn btn-danger btn-sm">&times;</button>
                                }
                            </td>
                        </tr>
                    }
                </table>
            </div>
            <div class="col-md-4">
                <div class="well">
                    <h3>Cart Summary</h3>
                    <hr />
                    <dl class="dl-horizontal">
                        <dt>Total Items</dt>
                        <dd>@Model.Sum(item => item.Quantity)</dd>

                        <dt>Cart Total</dt>
                        <dd>@String.Format("{0:C}", cartTotal)</dd>
                    </dl>
                    <hr /><a href="@Url.Action("Checkout", "Cart")" class="btn btn-success btn-block">Proceed to Checkout</a>

                </div>
            </div>
        </div>

    }
</div>
<div class="form-actions no-color" style="margin-top: 20px;">
    @Html.ActionLink("<< Back to Dashboard", "Dashboard", "Customer", null, new { @class = "btn btn-default" })
</div>
